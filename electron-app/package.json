{
  "name": "jejucentral-classroom-call",
  "version": "1.0.0",
  "private": true,
  "description": "제주중앙고등학교 교실 전자칠판 호출 알림 앱",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --dir",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "speaker": "^0.5.4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "kr.hs.jcgh.classroom-call",
    "productName": "교실 알림",
    "files": [
      "main.js",
      "preload.js",
      "audio-synth.js",
      "tts-win.js",
      "renderer-config.json",
      "icons/**",
      "../classroom.html"
    ],
    "extraResources": [
      { "from": "../classroom.html", "to": "classroom.html" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "icons/app.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
